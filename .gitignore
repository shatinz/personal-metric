# pyenv
#   For a library or package, you might want to ignore these files since the code is
#   intended to run in multiple environments; otherwise, check them in:
# .python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if used with a venv, the venv should be ignored.
# Pipfile.lock

# poetry
#   Similar to Pipfile.lock, poetry.lock can be submitted, but the venv should be ignored.
# poetry.lock

# pdm
#   Similar to Pipfile.lock, pdm.lock can be submitted, but the venv should be ignored.
# pdm.lock

# PEP 582; used by e.g. github.com/lincolnloop/layman and pdm
